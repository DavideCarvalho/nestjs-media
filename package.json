{
  "name": "nestjs-media-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Filesystem + media-library for NestJS (spatie-style), one package",
  "license": "MIT",
  "author": "Davide Carvalho",
  "packageManager": "pnpm@11.5.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.19.20",
    "reflect-metadata": "0.2.2",
    "turbo": "2.9.17",
    "typescript": "5.9.3",
    "unplugin-swc": "1.5.9",
    "@swc/core": "1.15.41",
    "vitest": "2.1.9"
  }
}
