{
  "name": "@dudousxd/nestjs-media-database-prisma",
  "version": "0.5.4",
  "description": "nestjs-media Prisma media store (consumer-managed schema)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*"
  },
  "devDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-media-testing": "workspace:*",
    "@prisma/client": "6.2.1",
    "@testcontainers/postgresql": "10.18.0",
    "prisma": "6.2.1",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
