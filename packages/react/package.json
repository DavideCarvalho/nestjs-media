{
  "name": "@dudousxd/nestjs-media-react",
  "version": "0.2.0",
  "description": "React hook + uploader component for nestjs-media (resumable tus)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dudousxd/nestjs-media-client": "workspace:*"
  },
  "devDependencies": {
    "@dudousxd/nestjs-media-client": "workspace:*",
    "@testing-library/react": "16.1.0",
    "@types/react": "19.0.7",
    "jsdom": "25.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  },
  "keywords": [
    "tanstack-intent"
  ]
}
