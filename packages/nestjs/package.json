{
  "name": "@dudousxd/nestjs-media",
  "version": "0.6.4",
  "description": "Filesystem + media-library for NestJS — one package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./storage": {
      "import": {
        "types": "./dist/storage.d.ts",
        "default": "./dist/storage.js"
      },
      "require": {
        "types": "./dist/storage.d.cts",
        "default": "./dist/storage.cjs"
      }
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.726.1",
    "@dudousxd/nestjs-media-client": "workspace:*",
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-media-disk-local": "workspace:*",
    "@dudousxd/nestjs-media-disk-s3": "workspace:*",
    "@dudousxd/nestjs-media-testing": "workspace:*",
    "@nestjs/common": "11.0.0",
    "@nestjs/core": "11.0.0",
    "@nestjs/platform-express": "11.0.0",
    "@nestjs/testing": "11.0.0",
    "express": "5.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "testcontainers": "10.18.0",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  },
  "keywords": [
    "tanstack-intent"
  ]
}
