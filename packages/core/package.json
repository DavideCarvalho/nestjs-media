{
  "name": "@dudousxd/nestjs-media-core",
  "version": "0.6.7",
  "description": "nestjs-media core — storage driver SPI and facade",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dudousxd/nestjs-diagnostics": "0.6.0"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
