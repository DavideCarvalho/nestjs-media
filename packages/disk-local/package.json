{
  "name": "@dudousxd/nestjs-media-disk-local",
  "version": "0.0.0",
  "description": "nestjs-media local filesystem driver",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": { "build": "tsup", "typecheck": "tsc -p tsconfig.json --noEmit" },
  "peerDependencies": { "@dudousxd/nestjs-media-core": "workspace:*" },
  "devDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-media-testing": "workspace:*",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
