{
  "name": "@dudousxd/nestjs-media-database-mikro-orm",
  "version": "0.5.3",
  "description": "nestjs-media MikroORM media store",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@mikro-orm/core": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-media-testing": "workspace:*",
    "@mikro-orm/core": "7.1.4",
    "@mikro-orm/postgresql": "7.1.4",
    "@mikro-orm/sqlite": "7.1.4",
    "testcontainers": "10.18.0",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
