{
  "name": "@dudousxd/nestjs-media-telescope",
  "version": "0.5.9",
  "description": "Telescope watcher for nestjs-media (consumes nestjs:media:* diagnostics)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-diagnostics": "^0.7.0",
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-telescope": "^1.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-diagnostics": "0.7.0",
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-telescope": "1.11.2",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
