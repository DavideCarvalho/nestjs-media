{
  "name": "@dudousxd/nestjs-media-disk-s3",
  "version": "0.0.0",
  "description": "nestjs-media S3 driver (presign + multipart-capable)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": { "build": "tsup", "typecheck": "tsc -p tsconfig.json --noEmit" },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@dudousxd/nestjs-media-core": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.726.1",
    "@aws-sdk/s3-request-presigner": "3.726.1",
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-media-testing": "workspace:*",
    "@smithy/util-stream": "3.3.1",
    "aws-sdk-client-mock": "4.1.0",
    "testcontainers": "10.18.0",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
