{
  "name": "@dudousxd/nestjs-media-testing",
  "version": "0.5.8",
  "description": "nestjs-media testing utilities — in-memory driver + driver conformance suite",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "vitest": "^2.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "tsup": "8.3.5",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
