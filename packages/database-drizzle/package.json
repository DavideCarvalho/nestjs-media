{
  "name": "@dudousxd/nestjs-media-database-drizzle",
  "version": "0.3.0",
  "description": "nestjs-media Drizzle media store (sqlite)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "drizzle-orm": "^0.38.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-media-core": "workspace:*",
    "@dudousxd/nestjs-media-testing": "workspace:*",
    "better-sqlite3": "11.8.1",
    "drizzle-orm": "0.38.4",
    "tsup": "8.3.5",
    "typescript": "5.9.3"
  }
}
